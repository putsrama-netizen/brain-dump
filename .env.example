# Copy this file to `.env` and paste your real values.
# The EXPO_PUBLIC_ prefix is required so Expo exposes the var to the
# JS bundle at build time (https://docs.expo.dev/guides/environment-variables/).
# The anon key is safe to ship to clients — it's gated by RLS policies in Supabase.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-key...
